h[0,0:int(M/2)+1] = np.exp(-(tt[0:int(M/2)+1])**2/(2*s**2))/(s*np.sqrt(2*np.pi))
h[0,-1:int(M/2):-1] = h[0,1:int(M/2)]

# Form toeplitz
H = toeplitz(h)
